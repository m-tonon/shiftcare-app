{
  "name": "shiftcare-app",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "install:all": "npm i && cd client && npm i && cd ../server && npm i"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
