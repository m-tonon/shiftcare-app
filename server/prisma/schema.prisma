generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Worker {
  id Int @id @default(autoincrement())
  name String
  role String
  availability String @default("AVAILABLE")
  slots ScheduleSlot[]
}

model ScheduleSlot {
  id Int @id @default(autoincrement())
  date String
  shift String
  workerId Int
  worker Worker @relation(fields: [workerId], references: [id])

  @@unique([date, shift, workerId])
}

model ShiftRule {
  id Int @id @default(autoincrement())
  shift String
  role String
  requiredCount Int

  @@unique([shift, role])
}

/// Per-date staffing requirement; overrides ShiftRule for that date+shift+role when present.
model ShiftRequirementOverride {
  id Int @id @default(autoincrement())
  date String
  shift String
  role String
  requiredCount Int

  @@unique([date, shift, role])
}